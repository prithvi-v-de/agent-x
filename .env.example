AWS_REGION=us-east-1
GITHUB_AGENT_IDENTITY_ARN=arn:aws:bedrock:us-east-1:YOUR_ACCOUNT:agent-identity/github-agent-XXXX
JIRA_AGENT_IDENTITY_ARN=arn:aws:bedrock:us-east-1:YOUR_ACCOUNT:agent-identity/jira-agent-XXXX
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
JIRA_CLIENT_ID=your_jira_oauth_client_id
JIRA_CLIENT_SECRET=your_jira_oauth_client_secret
APP_URL=http://localhost:8080
FLASK_SECRET_KEY=change-me-to-a-random-string
